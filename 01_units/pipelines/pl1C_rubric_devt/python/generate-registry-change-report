#!/usr/bin/env python3
"""Generate a Base Table registry change report across iteration history.

This script starts from a current indicator registry markdown file, discovers
previous iteration registries by remapping the iteration and registry version
tokens in the path, and writes a markdown matrix showing which Base Table rows
changed over time.

Matrix semantics:
- Rows are Base Table items keyed by `template_id`.
- Columns are discovered iteration labels such as `iter01`, `iter02`, ...
- Each cell is relative to the immediately previous discovered iteration:
  - `added`: the template row was absent previously and exists now
  - `removed`: the template row existed previously and is absent now
  - `changed`: the template row exists in both iterations but its Base Table
    content differs
  - empty: no change for that template row at that iteration
"""

from __future__ import annotations

import argparse
from datetime import datetime, timezone
import re
import sys
from pathlib import Path

from generate_rubric_and_manifest_from_indicator_registry import (
    collect_markdown_tables,
    collect_section_rows,
)


ITERATION_RE = re.compile(r"\b(iter\d+)\b", re.IGNORECASE)
REGISTRY_VERSION_PATH_RE = re.compile(r"(/registry_v)(\d+)(/)", re.IGNORECASE)
REGISTRY_FILENAME_VERSION_RE = re.compile(r"_v(\d+)(?=\.[^.]+$)", re.IGNORECASE)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Generate a Base Table registry change report across iteration history."
    )
    parser.add_argument(
        "--indicator-registry",
        type=Path,
        required=True,
        help="Path to the current iteration markdown indicator registry file.",
    )
    parser.add_argument(
        "--output-file",
        type=Path,
        required=False,
        help="Optional explicit output markdown path.",
    )
    parser.add_argument(
        "--iteration-label",
        type=str,
        required=False,
        help="Optional current iteration label override, e.g. iter15.",
    )
    parser.add_argument(
        "--baseline-iteration-label",
        type=str,
        required=False,
        help="Optional earliest iteration label to include, e.g. iter08.",
    )
    return parser.parse_args()


def parse_numeric_label(label: str, prefix: str) -> tuple[int, int] | None:
    match = re.fullmatch(rf"{prefix}(\d+)", label.strip().lower())
    if match is None:
        return None
    digits = match.group(1)
    return (int(digits), len(digits))


def format_numeric_label(prefix: str, number: int, width: int) -> str:
    return f"{prefix}{number:0{width}d}"


def derive_iteration_label(registry_path: Path, explicit_label: str | None) -> str:
    if explicit_label:
        return explicit_label.strip().lower()
    for part in registry_path.parts:
        match = ITERATION_RE.search(part)
        if match:
            return match.group(1).lower()
    match = ITERATION_RE.search(str(registry_path))
    if match:
        return match.group(1).lower()
    raise ValueError(f"Could not derive iteration label from registry path: {registry_path}")


def derive_iteration_history_labels(
    current_iteration_label: str,
    baseline_iteration_label: str | None,
) -> list[str]:
    current_parsed = parse_numeric_label(current_iteration_label, "iter")
    if current_parsed is None:
        return [current_iteration_label]
    current_number, width = current_parsed
    baseline_number = 1
    if baseline_iteration_label:
        baseline_parsed = parse_numeric_label(baseline_iteration_label, "iter")
        if baseline_parsed is None:
            raise ValueError(f"Invalid baseline iteration label: {baseline_iteration_label}")
        baseline_number = baseline_parsed[0]
    if baseline_number > current_number:
        raise ValueError(
            f"Baseline iteration {baseline_iteration_label} is after current iteration {current_iteration_label}"
        )
    return [
        format_numeric_label("iter", index, width)
        for index in range(baseline_number, current_number + 1)
    ]


def derive_target_version_label(current_iteration_label: str, target_iteration_label: str) -> str | None:
    current_parsed = parse_numeric_label(current_iteration_label, "iter")
    target_parsed = parse_numeric_label(target_iteration_label, "iter")
    if current_parsed is None or target_parsed is None:
        return None
    _, current_width = current_parsed
    target_number, _ = target_parsed
    return f"{target_number:0{current_width}d}"


def remap_registry_path_for_iteration(
    current_registry_path: Path,
    current_iteration_label: str,
    target_iteration_label: str,
) -> Path:
    if current_iteration_label == target_iteration_label:
        return current_registry_path
    target_text = re.sub(
        rf"/{re.escape(current_iteration_label)}(?=/|$)",
        f"/{target_iteration_label}",
        str(current_registry_path),
    )
    target_version = derive_target_version_label(current_iteration_label, target_iteration_label)
    if target_version is not None:
        target_text = REGISTRY_VERSION_PATH_RE.sub(rf"\g<1>{target_version}\g<3>", target_text)
    target_path = Path(target_text)
    if target_version is None:
        return target_path
    updated_name = REGISTRY_FILENAME_VERSION_RE.sub(f"_v{target_version}", target_path.name, count=1)
    if updated_name != target_path.name:
        target_path = target_path.with_name(updated_name)
    return target_path


def derive_assignment_output_prefix(registry_path: Path) -> str:
    match = re.match(r"^([A-Za-z0-9]+)_Layer1_IndicatorRegistry", registry_path.name)
    if not match:
        return "I"
    return f"I_{match.group(1)}"


def default_output_path(registry_path: Path, iteration_label: str) -> Path:
    prefix = derive_assignment_output_prefix(registry_path)
    return registry_path.parent / f"{prefix}_registry_change_report_{iteration_label}.md"


def normalize_whitespace(value: str) -> str:
    return re.sub(r"\s+", " ", value.strip())


def load_base_rows_by_template(registry_path: Path) -> dict[str, dict[str, str]]:
    tables = collect_markdown_tables(registry_path)
    base_rows = collect_section_rows(
        tables,
        "base table",
        required_columns={"template_id"},
        allow_field_value_records=True,
    )
    rows_by_template: dict[str, dict[str, str]] = {}
    for row in base_rows:
        template_id = normalize_whitespace(str(row.get("template_id", "")))
        if not template_id:
            continue
        normalized_row = {
            normalize_whitespace(str(key)): normalize_whitespace(str(value))
            for key, value in row.items()
            if normalize_whitespace(str(key))
        }
        rows_by_template[template_id] = normalized_row
    return rows_by_template


def template_sort_key(template_id: str) -> tuple[int, str]:
    normalized = template_id.strip().lower()
    if "_core_" in normalized:
        return (0, normalized)
    if "_adv_" in normalized:
        return (1, normalized)
    return (2, normalized)


def build_change_matrix(
    iteration_rows: list[tuple[str, dict[str, dict[str, str]]]],
) -> tuple[list[str], list[list[str]]]:
    iteration_labels = [label for label, _rows in iteration_rows]
    all_template_ids = sorted(
        {template_id for _label, rows in iteration_rows for template_id in rows},
        key=template_sort_key,
    )

    rows: list[list[str]] = []
    for template_id in all_template_ids:
        description = ""
        for _label, row_map in reversed(iteration_rows):
            row = row_map.get(template_id)
            if row is None:
                continue
            description = row.get("sbo_short_description", "")
            if description:
                break
        status_cells: list[str] = []
        previous_row: dict[str, str] | None = None
        for column_index, (_iteration_label, row_map) in enumerate(iteration_rows):
            current_row = row_map.get(template_id)
            if column_index == 0:
                status_cells.append("")
                previous_row = current_row
                continue
            if previous_row is None and current_row is not None:
                status_cells.append("added")
            elif previous_row is not None and current_row is None:
                status_cells.append("removed")
            elif previous_row is not None and current_row is not None and previous_row != current_row:
                status_cells.append("changed")
            else:
                status_cells.append("")
            previous_row = current_row
        rows.append([template_id, description, *status_cells])
    return iteration_labels, rows


def render_markdown_table(headers: list[str], rows: list[list[str]]) -> str:
    separator = ["---"] * len(headers)
    lines = [
        "| " + " | ".join(headers) + " |",
        "| " + " | ".join(separator) + " |",
    ]
    for row in rows:
        lines.append("| " + " | ".join(row) + " |")
    return "\n".join(lines)


def quote_yaml_string(value: str) -> str:
    escaped = value.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{escaped}"'


def render_yaml_frontmatter(
    output_path: Path,
    current_registry_path: Path,
    iteration_paths: list[tuple[str, Path]],
) -> str:
    lines = [
        "---\n",
        f"generated_at_utc: {quote_yaml_string(datetime.now(timezone.utc).isoformat(timespec='seconds'))}\n",
        "generator:\n",
        f"  script: {quote_yaml_string(str(Path(__file__).resolve()))}\n",
        "output_file:\n",
        f"  path: {quote_yaml_string(str(output_path))}\n",
        f"  name: {quote_yaml_string(output_path.name)}\n",
        "current_registry:\n",
        f"  path: {quote_yaml_string(str(current_registry_path))}\n",
        "iterations:\n",
    ]
    for iteration_label, registry_path in iteration_paths:
        lines.extend(
            [
                "  - label: " + quote_yaml_string(iteration_label) + "\n",
                "    registry: " + quote_yaml_string(str(registry_path)) + "\n",
            ]
        )
    lines.append("---\n")
    return "".join(lines)


def render_report(
    output_path: Path,
    current_registry_path: Path,
    iteration_paths: list[tuple[str, Path]],
    iteration_labels: list[str],
    rows: list[list[str]],
) -> str:
    headers = ["template_id", "sbo_short_description", *iteration_labels]
    body = [
        render_yaml_frontmatter(output_path, current_registry_path, iteration_paths),
        "\n",
        "# Registry Change Report\n",
        "\n",
        "This matrix compares each Base Table `template_id` against the immediately previous discovered iteration column.\n",
        "\n",
        "Cell values:\n",
        "- `added`: row absent previously and present now\n",
        "- `removed`: row present previously and absent now\n",
        "- `changed`: row present in both iterations but Base Table content differs\n",
        "- empty: no change\n",
        "\n",
        render_markdown_table(headers, rows),
        "\n",
    ]
    return "".join(body)


def main() -> int:
    args = parse_args()
    current_registry_path = args.indicator_registry.resolve()
    if not current_registry_path.exists() or not current_registry_path.is_file():
        print(f"Error: indicator registry file not found: {current_registry_path}", file=sys.stderr)
        return 1

    try:
        current_iteration_label = derive_iteration_label(current_registry_path, args.iteration_label)
        candidate_labels = derive_iteration_history_labels(
            current_iteration_label,
            args.baseline_iteration_label.lower() if args.baseline_iteration_label else None,
        )
    except ValueError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    iteration_paths: list[tuple[str, Path]] = []
    for iteration_label in candidate_labels:
        candidate_path = remap_registry_path_for_iteration(
            current_registry_path,
            current_iteration_label,
            iteration_label,
        )
        if candidate_path.exists() and candidate_path.is_file():
            iteration_paths.append((iteration_label, candidate_path))

    if not iteration_paths:
        print("Error: no registry files were found for the requested iteration history.", file=sys.stderr)
        return 1

    iteration_rows = [
        (iteration_label, load_base_rows_by_template(registry_path))
        for iteration_label, registry_path in iteration_paths
    ]
    iteration_labels, rows = build_change_matrix(iteration_rows)
    output_path = args.output_file.resolve() if args.output_file else default_output_path(
        current_registry_path,
        current_iteration_label,
    )
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_text = render_report(output_path, current_registry_path, iteration_paths, iteration_labels, rows)
    output_path.write_text(output_text, encoding="utf-8")
    print(output_path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
