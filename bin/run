#!/usr/bin/env bash
set -e

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ "$#" -lt 2 ]; then
  echo "Usage:"
  echo "  bin/run pipeline <name> <command> [args...]"
  echo "  bin/run app <name> <command> [args...]"
  exit 1
fi

TYPE="$1"
NAME="$2"
shift 2

case "$TYPE" in
  pipeline)
    python -m "$NAME" "$@"
    ;;
  app)
    python -m "$NAME" "$@"
    ;;
  *)
    echo "Unknown type: $TYPE"
    exit 1
    ;;
esac
